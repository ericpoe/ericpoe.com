---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import PaginationNav from '../../components/PaginationNav.astro';
import PostFeed from '../../components/PostFeed.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PAGE_SIZE, getTaxonomyItems } from '../../utils/blog';
import { formatTitleMla } from '../../utils/titleCase';

export const getStaticPaths = (async () => {
  const categories = await getTaxonomyItems('categories');
  return categories.map((category) => ({
    params: { category: category.slug },
    props: {
      categoryName: category.name,
      categorySlug: category.slug,
      posts: category.posts.slice(0, PAGE_SIZE),
      totalPages: category.totalPages,
    },
  }));
}) satisfies GetStaticPaths;

const { categoryName, categorySlug, posts, totalPages } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;

if (!posts?.length) {
  return Astro.redirect('/404');
}
---

<BaseLayout pathname={`/category/${categorySlug}/`}>
  <section id="categoryPosts" class="max-w-3xl w-full mx-auto px-4 md:px-6 py-10 md:py-12 space-y-8 md:space-y-10">
    <h1 class="text-3xl md:text-4xl font-semibold dark:text-indigo-100">{formatTitleMla(categoryName)}</h1>
    <PostFeed posts={posts} />
    <PaginationNav nextHref={totalPages > 1 ? `/category/${categorySlug}/page/2/` : undefined} />
  </section>
</BaseLayout>
