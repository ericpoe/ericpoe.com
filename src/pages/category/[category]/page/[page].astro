---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import type { CollectionEntry } from 'astro:content';
import PaginationNav from '../../../../components/PaginationNav.astro';
import PostFeed from '../../../../components/PostFeed.astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { PAGE_SIZE, getTaxonomyItems, paginatePosts } from '../../../../utils/blog';
import { formatTitleMla } from '../../../../utils/titleCase';

export const getStaticPaths = (async () => {
  const categories = await getTaxonomyItems('categories');

  const paths: Array<{
    params: { category: string; page: string };
    props: {
      categoryName: string;
      categorySlug: string;
      pageNumber: number;
      totalPages: number;
      posts: CollectionEntry<'blog'>[];
    };
  }> = [];

  for (const category of categories) {
    for (let page = 2; page <= category.totalPages; page++) {
      paths.push({
        params: { category: category.slug, page: String(page) },
        props: {
          categoryName: category.name,
          categorySlug: category.slug,
          ...paginatePosts(category.posts, page, PAGE_SIZE),
        },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { categoryName, categorySlug, pageNumber, totalPages, posts } = Astro.props as InferGetStaticPropsType<
  typeof getStaticPaths
>;

if (!posts?.length) {
  return Astro.redirect('/404');
}
---

<BaseLayout pathname={`/category/${categorySlug}/page/${pageNumber}/`}>
  <section id="categoryPosts" class="max-w-3xl w-full mx-auto px-4 md:px-6 py-10 md:py-12 space-y-8 md:space-y-10">
    <h1 class="text-3xl md:text-4xl font-semibold dark:text-indigo-100">{formatTitleMla(categoryName)}</h1>
    <PostFeed posts={posts} />
    <PaginationNav
      previousHref={pageNumber === 2
        ? `/category/${categorySlug}/`
        : `/category/${categorySlug}/page/${pageNumber - 1}/`}
      nextHref={pageNumber < totalPages ? `/category/${categorySlug}/page/${pageNumber + 1}/` : undefined}
    />
  </section>
</BaseLayout>
