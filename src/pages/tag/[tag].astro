---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import PaginationNav from '../../components/PaginationNav.astro';
import PostFeed from '../../components/PostFeed.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PAGE_SIZE, getTaxonomyItems } from '../../utils/blog';
import { formatTitleMla } from '../../utils/titleCase';

export const getStaticPaths = (async () => {
  const tags = await getTaxonomyItems('tags');
  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tagName: tag.name,
      tagSlug: tag.slug,
      posts: tag.posts.slice(0, PAGE_SIZE),
      totalPages: tag.totalPages,
    },
  }));
}) satisfies GetStaticPaths;

const { tagName, tagSlug, posts, totalPages } = Astro.props as InferGetStaticPropsType<typeof getStaticPaths>;

if (!posts?.length) {
  return Astro.redirect('/404');
}
---

<BaseLayout pathname={`/tag/${tagSlug}/`}>
  <section id="tagPosts" class="max-w-3xl w-full mx-auto px-4 md:px-6 py-10 md:py-12 space-y-8 md:space-y-10">
    <h1 class="text-3xl md:text-4xl font-semibold dark:text-indigo-100">
      {formatTitleMla(tagName.replace(/-/g, ' '))}
    </h1>
    <PostFeed posts={posts} />
    <PaginationNav nextHref={totalPages > 1 ? `/tag/${tagSlug}/page/2/` : undefined} />
  </section>
</BaseLayout>
