---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import type { CollectionEntry } from 'astro:content';
import PaginationNav from '../../../../components/PaginationNav.astro';
import PostFeed from '../../../../components/PostFeed.astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { PAGE_SIZE, getTaxonomyItems, paginatePosts } from '../../../../utils/blog';
import { formatTitleMla } from '../../../../utils/titleCase';

export const getStaticPaths = (async () => {
  const tags = await getTaxonomyItems('tags');

  const paths: Array<{
    params: { tag: string; page: string };
    props: {
      tagName: string;
      tagSlug: string;
      pageNumber: number;
      totalPages: number;
      posts: CollectionEntry<'blog'>[];
    };
  }> = [];

  for (const tag of tags) {
    for (let page = 2; page <= tag.totalPages; page++) {
      paths.push({
        params: { tag: tag.slug, page: String(page) },
        props: {
          tagName: tag.name,
          tagSlug: tag.slug,
          ...paginatePosts(tag.posts, page, PAGE_SIZE),
        },
      });
    }
  }

  return paths;
}) satisfies GetStaticPaths;

const { tagName, tagSlug, pageNumber, totalPages, posts } = Astro.props as InferGetStaticPropsType<
  typeof getStaticPaths
>;

if (!posts?.length) {
  return Astro.redirect('/404');
}
---

<BaseLayout pathname={`/tag/${tagSlug}/page/${pageNumber}/`}>
  <section id="tagPosts" class="max-w-3xl w-full mx-auto px-4 md:px-6 py-10 md:py-12 space-y-8 md:space-y-10">
    <h1 class="text-3xl md:text-4xl font-semibold dark:text-indigo-100">
      {formatTitleMla(tagName.replace(/-/g, ' '))}
    </h1>
    <PostFeed posts={posts} />
    <PaginationNav
      previousHref={pageNumber === 2 ? `/tag/${tagSlug}/` : `/tag/${tagSlug}/page/${pageNumber - 1}/`}
      nextHref={pageNumber < totalPages ? `/tag/${tagSlug}/page/${pageNumber + 1}/` : undefined}
    />
  </section>
</BaseLayout>
