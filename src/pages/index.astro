---
import PaginationNav from '../components/PaginationNav.astro';
import PostFeed from '../components/PostFeed.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts, paginatePosts } from '../utils/blog';

const { pageNumber, totalPages, posts } = paginatePosts(await getAllPosts(), 1);
---

<BaseLayout pathname="/">
  <section id="latestPosts" class="max-w-3xl w-full mx-auto px-4 md:px-6 py-10 md:py-12 space-y-8 md:space-y-10">
    <h1 class="text-3xl md:text-4xl font-semibold dark:text-indigo-100">Latest Posts</h1>
    <PostFeed posts={posts} />
    <PaginationNav nextHref={pageNumber < totalPages ? `/page/${pageNumber + 1}/` : undefined} />
  </section>
</BaseLayout>
