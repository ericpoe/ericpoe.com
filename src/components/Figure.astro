---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { sanitizeCaptionHtml } from '../utils/sanitizeCaptionHtml';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'auto' | 'sync';
  sizes?: string;
  format?: 'avif' | 'jpeg' | 'jpg' | 'png' | 'webp';
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  caption,
  loading = 'lazy',
  decoding = 'async',
  sizes = '100vw',
  format,
  width,
  height,
}: Props = Astro.props;

const isImageMetadata = typeof src === 'object' && src !== null && 'src' in src && 'width' in src && 'height' in src;
const resolvedSrc = typeof src === 'string' ? src : src.src;
const safeCaption = typeof caption === 'string' ? sanitizeCaptionHtml(caption) : '';
---

<figure class="my-4">
  {
    isImageMetadata ? (
      <Image
        src={src}
        alt={alt}
        class="w-full rounded"
        loading={loading}
        decoding={decoding}
        sizes={sizes}
        {...(format ? { format } : {})}
      />
    ) : (
      <img
        src={resolvedSrc}
        alt={alt}
        class="w-full rounded"
        loading={loading}
        decoding={decoding}
        sizes={sizes}
        width={width}
        height={height}
      />
    )
  }
  {safeCaption && <figcaption class="mt-2 text-sm" set:html={safeCaption} />}
</figure>
