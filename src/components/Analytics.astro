---
import { PUBLIC_GA_MEASUREMENT_ID } from 'astro:env/client';

const measurementId = PUBLIC_GA_MEASUREMENT_ID;
const isProd = import.meta.env.PROD;
const shouldLoad = Boolean(isProd && measurementId);
---

{shouldLoad && <script is:inline src="/scripts/analytics.js" data-measurement-id={measurementId} />}
